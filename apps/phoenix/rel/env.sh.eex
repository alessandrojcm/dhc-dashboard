# Fly.io private networking uses IPv6 addresses for distributed Erlang.
# Configure a long node name before the release starts so DNSCluster can
# discover peer Machines without logging longname/connection-id errors.
if [ -n "${FLY_PRIVATE_IP}" ]; then
  export RELEASE_DISTRIBUTION=name
  export RELEASE_NODE="${FLY_APP_NAME:-dhc-dashboard}-${FLY_IMAGE_REF##*-}@${FLY_PRIVATE_IP}"
fi
